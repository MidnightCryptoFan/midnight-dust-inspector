# Public Midnight Indexer GraphQL endpoint.
NEXT_PUBLIC_MIDNIGHT_INDEXER_URL=https://indexer.mainnet.midnight.network/api/v4/graphql

# Midnight DApp Connector network id used when connecting a Midnight wallet.
NEXT_PUBLIC_MIDNIGHT_NETWORK_ID=mainnet

# Optional server-only override for deployed environments.
MIDNIGHT_INDEXER_URL=https://indexer.mainnet.midnight.network/api/v4/graphql

# Set to true only for local development without a live indexer.
NEXT_PUBLIC_USE_MOCK_INDEXER=false

# Optional: set to "dev" or "rc" to show a channel badge in the footer.
# Leave unset on the stable/main branch.
# NEXT_PUBLIC_APP_CHANNEL=dev

# Read-only Cardano provider used for the on-chain timeline.
CARDANO_KOIOS_URL=https://api.koios.rest/api/v1
CARDANO_TIMELINE_TRANSACTION_LIMIT=25

# Cardano Native Asset identifier for mainnet NIGHT. Override if Midnight changes it.
CARDANO_NIGHT_POLICY_ID=0691b2fecca1ac4f53cb6dfb00b7013e561d1f34403b957cbb5af1fa
CARDANO_NIGHT_ASSET_NAME=4e49474854
